# ══════════════════════════════════════════════════════════
#  SIPRE-AVC Backend — Ficheiro de Ambiente
#  1. Copie este ficheiro: cp .env.example .env
#  2. Preencha DB_PASSWORD com a sua senha do Aiven
#  3. Preencha JWT_SECRET (gere com o comando abaixo)
# ══════════════════════════════════════════════════════════

# ── PostgreSQL Aiven (já preenchido com os seus dados) ────
DB_HOST=pg-2f6c26f4-sipreavc-3047.d.aivencloud.com
DB_PORT=23447
DB_USER=avnadmin
DB_PASSWORD=COLOQUE_AQUI_SUA_SENHA_AIVEN
DB_NAME=defaultdb

# ── Servidor ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT (gere a chave com este comando no terminal) ───────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_E_COLOQUE_AQUI_UMA_CHAVE_LONGA
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173


